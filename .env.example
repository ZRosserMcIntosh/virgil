# ── Core ──────────────────────────────────────────────────────────────────────
# Postgres pooled connection (Supabase pgBouncer). Used by app at runtime.
DATABASE_URL="postgresql://USER:PASS@HOST:6543/postgres?pgbouncer=true&connection_limit=1"
# Direct connection. Used by Prisma migrations and `psql` for raw SQL.
DIRECT_URL="postgresql://USER:PASS@HOST:5432/postgres"

# ── Supabase ──────────────────────────────────────────────────────────────────
# Public — safe to expose in browser.
NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."

# ── NextAuth ──────────────────────────────────────────────────────────────────
# Production: https://virgil.zrossermcintosh.com
# Local dev:  http://localhost:3000
NEXTAUTH_URL="https://virgil.zrossermcintosh.com"
NEXTAUTH_SECRET="generate-with: openssl rand -base64 64"

# ── Owner identity (singleton) ────────────────────────────────────────────────
VIRGIL_OWNER_EMAIL="rosser@example.com"
# v0 development credential. Replace with WebAuthn/passkeys before production.
VIRGIL_OWNER_PASSWORD="change-me-immediately"

# ── Encryption ────────────────────────────────────────────────────────────────
# 32 bytes, base64. Generate: openssl rand -base64 32
ENCRYPTION_KEY=""

# ── Policy switches ───────────────────────────────────────────────────────────
# When true, disables ALL cloud providers (mock + local only).
VIRGIL_LOCAL_ONLY="false"
# When true, prompt-injection / authority-claim hits auto-trigger Black Door.
VIRGIL_AUTO_BLACK_DOOR="true"

# ── LLM providers (optional in v0; mock used when absent) ─────────────────────
OPENAI_API_KEY=""
ANTHROPIC_API_KEY=""

# ── AWS (S3 cold storage + KMS envelope keys) ─────────────────────────────────
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
S3_BUCKET_VIRGIL=""
KMS_KEY_ID=""

# ── Cloudflare (Access in front of /login + /api/*) ───────────────────────────
CLOUDFLARE_ACCOUNT_ID=""
CLOUDFLARE_ACCESS_AUD=""

# ── Observability (optional) ──────────────────────────────────────────────────
SENTRY_DSN=""
RESEND_API_KEY=""
