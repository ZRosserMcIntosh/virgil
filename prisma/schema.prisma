// ─────────────────────────────────────────────────────────────────────────────
// VIRGIL — database schema
//
// One owner. At most one Pepper. Everyone else is delegate, guest, stranger,
// or adversary. The application enforces uniqueness for OWNER and PEPPER both
// in code and via partial unique indexes added in migrations
// (see prisma/migrations/*_singleton_indexes/migration.sql when generated).
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider      = "prisma-client-js"
  // Vercel runs on Amazon Linux 2023 (RHEL/OpenSSL 3). Bundle that target so
  // serverless cold-starts don't try to download engines at runtime.
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ── Identity ────────────────────────────────────────────────────────────────

enum IdentityType {
  OWNER       // Rosser. Exactly one. Enforced in app + partial unique index.
  PEPPER      // The protected intimate. At most one. Same enforcement.
  DELEGATE    // Function-scoped trusted operator.
  GUEST       // Narrow, temporary access.
  STRANGER    // Unknown. Default. Access denied.
  ADVERSARY   // Known/suspected hostile. Lockdown response, evidence preserved.
}

enum PepperTrust {
  PEPPER_BASIC
  PEPPER_TRUSTED
  PEPPER_HOUSEHOLD
  PEPPER_PRIMARY
}

model User {
  id            String        @id @default(cuid())
  email         String        @unique
  name          String?
  identity      IdentityType  @default(STRANGER)
  pepperTrust   PepperTrust?
  suspended     Boolean       @default(false)
  suspendedAt   DateTime?
  suspendReason String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  sessions        Session[]
  trustedDevices  TrustedDevice[]
  memories        Memory[]
  approvals       Approval[]       @relation("ApprovalRequester")
  securityEvents  SecurityEvent[]
  auditEvents     AuditEvent[]
  providerCalls   ProviderCall[]
  scopeGrants     ScopeGrant[]
  projects        Project[]
  questions       VirgilQuestion[]
  questionAnswers VirgilQuestionAnswer[]
  memoryInferences VirgilMemoryInference[]
  profileDomains  VirgilProfileDomain[]
  questionSessions VirgilQuestionSession[]

  // ── Veronica principal fields (Stella only) ──
  cpfHash                String?         // HMAC-SHA256 of CPF, never plaintext
  principalKeyHash       String?         // SHA-256 of derived key — for login verification only
  passwordHash           String?         // bcrypt hash of Stella's chosen password
  veronicaOnboarded      Boolean         @default(false)
  veronicaPrivacyAudit   VeronicaPrivacyAudit[]

  @@index([identity])
}

/// Per-user permission grants for DELEGATE / GUEST / PEPPER. OWNER ignores it.
model ScopeGrant {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  scope       String   // e.g. "calendar.availability", "katura.tasks.read"
  allowed     Boolean  @default(true)
  reason      String?
  expiresAt   DateTime?
  createdAt   DateTime @default(now())

  @@unique([userId, scope])
  @@index([userId])
}

model Session {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionToken    String   @unique
  trustedDeviceId String?
  trustedDevice   TrustedDevice? @relation(fields: [trustedDeviceId], references: [id])
  ipHash          String?
  userAgent       String?
  riskScore       Int      @default(50)
  authLevel       Int      @default(1)
  voiceVerified   Boolean  @default(false)
  strongVerified  Boolean  @default(false)
  lastVerifiedAt  DateTime?
  expiresAt       DateTime
  createdAt       DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model TrustedDevice {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name            String
  fingerprintHash String   @unique
  firstSeenAt     DateTime @default(now())
  lastSeenAt      DateTime @default(now())
  trusted         Boolean  @default(false)
  revokedAt       DateTime?
  notes           String?
  sessions        Session[]

  @@index([userId])
}

// ── Lockdown (singleton) ────────────────────────────────────────────────────

/// Single-row table. When `engaged = true`, every API path returns
/// "Access denied." regardless of identity, except a clear-from-trusted-device
/// flow performed by OWNER with HARD_APPROVAL. The seed creates this row;
/// never delete it.
model LockdownState {
  id              String   @id @default("LOCKDOWN")
  engaged         Boolean  @default(false)
  reason          String?
  engagedAt       DateTime?
  engagedByUserId String?
  clearedAt       DateTime?
  updatedAt       DateTime @updatedAt
}

// ── Denial list ─────────────────────────────────────────────────────────────

enum DenialKind {
  IP_HASH
  DEVICE_FINGERPRINT
  USER_AGENT_HASH
  EMAIL
}

model DenialEntry {
  id          String     @id @default(cuid())
  kind        DenialKind
  valueHash   String
  reason      String
  severity    Severity   @default(HIGH)
  createdAt   DateTime   @default(now())
  expiresAt   DateTime?  // null = permanent

  @@unique([kind, valueHash])
  @@index([expiresAt])
}

// ── Adversary scoring ───────────────────────────────────────────────────────

model AdversaryScore {
  id          String   @id @default(cuid())
  subjectKey  String   @unique // "ip:<hash>" | "fp:<hash>" | "ua:<hash>"
  score       Int      @default(0)
  hits        Int      @default(0)
  lastHitAt   DateTime @default(now())
  createdAt   DateTime @default(now())
}

// ── Memory ──────────────────────────────────────────────────────────────────

enum SensitivityLevel {
  PUBLIC
  BUSINESS_INTERNAL
  BUSINESS_CONFIDENTIAL
  PERSONAL_PRIVATE
  PERSONAL_SACRED
  SECURITY_SECRET
  NEVER_SEND_TO_CLOUD
}

enum MemoryCategory {
  PERMANENT_FACT
  SESSION_CONTEXT
  PROJECT
  PERSON
  BUSINESS
  PERSONAL
  DECISION_JOURNAL
  CORRECTION
  SECURITY
  NEVER_CLOUD
  PEPPER
  WORKING_STYLE
}

enum MemoryStatus {
  ACTIVE
  PROPOSED
  SUPERSEDED
  ARCHIVED
  DELETED
  REJECTED
}

enum MemorySourceType {
  USER_DIRECT
  CHAT_SUMMARY
  CONNECTOR
  DOCUMENT
  EMAIL
  CALENDAR
  CODE
  ISSUE
  PR
  SYSTEM
  IMPORT
  INFERENCE
}

enum MemoryWritePolicy {
  AUTO_SAFE
  REQUIRE_OWNER_REVIEW
  REQUIRE_EXPLICIT_APPROVAL
  NEVER_WRITE
}

enum MemoryRetrievalRole {
  SYSTEM_CONTEXT
  USER_CONTEXT
  BRIEFING
  SEARCH_RESULT
  ADMIN_REVIEW
}

enum MemoryEdgeType {
  RELATED_TO
  CONTRADICTS
  SUPPORTS
  SUPERSEDES
  ABOUT_PERSON
  ABOUT_PROJECT
  CAUSED_BY
  RESULTED_IN
  SHOULD_REMIND_WITH
}

model Memory {
  id                 String            @id @default(cuid())
  ownerId            String
  owner              User              @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  title              String
  content            String?
  encryptedContent   String?
  encrypted          Boolean           @default(false)
  summary            String?
  searchText         String?
  category           MemoryCategory
  sensitivity        SensitivityLevel  @default(BUSINESS_INTERNAL)
  status             MemoryStatus      @default(ACTIVE)
  sourceType         MemorySourceType  @default(USER_DIRECT)
  sourceId           String?
  sourceUrl          String?
  sourceTimestamp    DateTime?
  writePolicy        MemoryWritePolicy @default(REQUIRE_OWNER_REVIEW)
  confidence         Float             @default(0.8)
  importance         Int               @default(50)
  source             String?
  cloudAllowed       Boolean           @default(false)
  neverSendToCloud   Boolean           @default(false)
  tags               String[]          @default([])
  pinned             Boolean           @default(false)
  verified           Boolean           @default(false)
  accessCount        Int               @default(0)
  lastAccessedAt     DateTime?
  decayAfter         DateTime?
  supersedesMemoryId String?
  supersededById     String?
  /// If non-null, this memory may be shown to the Pepper if their pepperTrust
  /// meets/exceeds this floor. Owner ignores this field.
  pepperVisibility   PepperTrust?
  projectId          String?
  project            Project?          @relation(fields: [projectId], references: [id])
  personRef          String?
  createdBy          String?
  expiresAt          DateTime?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  chunks             MemoryChunk[]
  fromEdges          MemoryEdge[]      @relation("EdgeFrom")
  toEdges            MemoryEdge[]      @relation("EdgeTo")

  @@index([ownerId])
  @@index([category])
  @@index([sensitivity])
  @@index([projectId])
  @@index([status])
  @@index([sourceType])
  @@index([importance])
  @@index([lastAccessedAt])
  @@index([createdAt])
  @@index([personRef])
  @@index([ownerId, status, category])
}

model MemoryChunk {
  id               String   @id @default(cuid())
  memoryId         String
  memory           Memory   @relation(fields: [memoryId], references: [id], onDelete: Cascade)
  ordinal          Int
  content          String?
  encryptedContent String?
  encrypted        Boolean  @default(false)
  summary          String?
  searchText       String?
  tokenEstimate    Int      @default(0)
  createdAt        DateTime @default(now())

  @@unique([memoryId, ordinal])
  @@index([memoryId])
}

model MemoryAccessLog {
  id          String              @id @default(cuid())
  memoryId    String?
  userId      String?
  identity    IdentityType?
  role        MemoryRetrievalRole
  action      String
  allowed     Boolean
  reason      String?
  sensitivity SensitivityLevel?
  projectId   String?
  queryHash   String?
  createdAt   DateTime            @default(now())

  @@index([memoryId])
  @@index([userId])
  @@index([identity])
  @@index([createdAt])
  @@index([projectId])
}

model MemoryEdge {
  id           String         @id @default(cuid())
  fromMemoryId String
  toMemoryId   String
  fromMemory   Memory         @relation("EdgeFrom", fields: [fromMemoryId], references: [id], onDelete: Cascade)
  toMemory     Memory         @relation("EdgeTo",   fields: [toMemoryId],   references: [id], onDelete: Cascade)
  type         MemoryEdgeType
  weight       Float          @default(1.0)
  reason       String?
  createdAt    DateTime       @default(now())

  @@unique([fromMemoryId, toMemoryId, type])
  @@index([fromMemoryId])
  @@index([toMemoryId])
  @@index([type])
}

model MemoryReviewQueue {
  id               String           @id @default(cuid())
  proposedTitle    String
  proposedContent  String
  proposedSummary  String?
  category         MemoryCategory
  sensitivity      SensitivityLevel
  sourceType       MemorySourceType
  sourceId         String?
  projectId        String?
  personRef        String?
  confidence       Float            @default(0.7)
  importance       Int              @default(50)
  reason           String
  status           ApprovalStatus   @default(PENDING)
  createdByUserId  String?
  decidedAt        DateTime?
  createdAt        DateTime         @default(now())

  @@index([status])
  @@index([category])
  @@index([sensitivity])
  @@index([projectId])
}

// ── Projects ────────────────────────────────────────────────────────────────

enum ProjectType {
  KATURA
  K99
  MAVERICK
  PERSONAL
  OTHER
}

enum ProjectStatus {
  ACTIVE
  PLANNING
  PAUSED
  ARCHIVED
}

enum HealthStatus {
  GREEN
  YELLOW
  RED
  UNKNOWN
}

model Project {
  id                String        @id @default(cuid())
  slug              String        @unique
  name              String        @unique
  description       String?
  type              ProjectType
  status            ProjectStatus @default(ACTIVE)
  priority          Int           @default(50)
  ownerId           String
  owner             User          @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  ownerLabel        String        @default("Rosser")
  connectedRepos    String[]      @default([])
  connectedDomains  String[]      @default([])
  connectedAgentIds String[]      @default([])
  healthScore       Int           @default(50)
  health            HealthStatus  @default(UNKNOWN)
  lastBriefingAt    DateTime?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  memories          Memory[]
  approvals         Approval[]
}

// ── Agents ──────────────────────────────────────────────────────────────────

enum AgentStatus {
  ACTIVE
  IDLE
  DISABLED
  QUARANTINED
}

model Agent {
  id                String      @id @default(cuid())
  name              String      @unique
  domain            String
  description       String
  status            AgentStatus @default(IDLE)
  accessLevel       Int         @default(2)
  connectorScopes   String[]    @default([])
  reportsTo         String?
  lastReportAt      DateTime?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
}

// ── Approval Queue ──────────────────────────────────────────────────────────

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
  EXECUTED
}

enum RiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ActionPhase {
  OBSERVE
  ADVISE
  PREPARE
  STAGE
  EXECUTE
  CONFIRM
  ABORT
}

model Approval {
  id                    String           @id @default(cuid())
  requesterId           String
  requester             User             @relation("ApprovalRequester", fields: [requesterId], references: [id])
  actionType            String
  phase                 ActionPhase      @default(PREPARE)
  title                 String
  summary               String
  payload               Json
  riskLevel             RiskLevel        @default(MEDIUM)
  sensitivityLevel      SensitivityLevel @default(BUSINESS_INTERNAL)
  approvalRequiredLevel Int              @default(5)
  preparedByModel       String?
  preparedByTool        String?
  explanation           String?
  rollbackPlan          String?
  status                ApprovalStatus   @default(PENDING)
  projectId             String?
  project               Project?         @relation(fields: [projectId], references: [id])
  createdAt             DateTime         @default(now())
  expiresAt             DateTime?
  decidedAt             DateTime?
  executedAt            DateTime?

  @@index([status])
  @@index([requesterId])
}

// ── Security Events ─────────────────────────────────────────────────────────

enum SecurityEventType {
  FAILED_LOGIN
  UNKNOWN_DEVICE
  SUSPICIOUS_REQUEST
  PROMPT_INJECTION
  UNAUTHORIZED_MEMORY_ACCESS
  SECRETS_REQUEST
  PRIVATE_PERSON_REQUEST
  BROAD_EXPORT_ATTEMPT
  CONNECTOR_ACCESS_ATTEMPT
  FAILED_VOICE_VERIFICATION
  SESSION_ESCALATION
  LOCKDOWN_TRIGGERED
  LOCKDOWN_CLEARED
  EMERGENCY_UNLOCK
  MANUAL_OVERRIDE
  BLACK_DOOR_TRIGGERED
  ADVERSARY_FLAGGED
  DENIAL_LIST_ADDED
  AUTHORITY_CLAIM
  IMPERSONATION_ATTEMPT
  HONEYPOT_HIT
  SYSTEM_BOOT
}

enum Severity {
  INFO
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model SecurityEvent {
  id            String            @id @default(cuid())
  userId        String?
  user          User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  type          SecurityEventType
  severity      Severity          @default(MEDIUM)
  ipHash        String?
  userAgent     String?
  summary       String
  metadata      Json?
  resolved      Boolean           @default(false)
  resolvedAt    DateTime?
  createdAt     DateTime          @default(now())

  @@index([type])
  @@index([severity])
  @@index([createdAt])
}

// ── Audit ───────────────────────────────────────────────────────────────────

model AuditEvent {
  id                  String   @id @default(cuid())
  userId              String?
  user                User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  sessionId           String?
  trustLevel          Int?
  identity            IdentityType?
  sensitivity         SensitivityLevel?
  actionRequested     String
  actionTaken         String
  toolUsed             String?
  providerUsed        String?
  modelUsed           String?
  approvalId          String?
  approvalRequired    Boolean  @default(false)
  sentToCloud         Boolean  @default(false)
  redactionApplied    Boolean  @default(false)
  result              String   // "ok" | "denied" | "error" | "staged" | "lockdown"
  resultDetail        String?
  createdAt           DateTime @default(now())

  @@index([createdAt])
  @@index([userId])
}

// ── Connectors ──────────────────────────────────────────────────────────────

enum ConnectorKind {
  GITHUB
  GMAIL
  GOOGLE_CALENDAR
  KATURA
  K99
  MAVERICK
  STRIPE
  ANALYTICS
  VERCEL
  CLOUDFLARE
  AWS_S3
  AWS_KMS
  RESEND
  SENTRY
  LINEAR
  NOTION
  SLACK
  CUSTOM
}

model ConnectorConfig {
  id              String        @id @default(cuid())
  kind            ConnectorKind
  name            String
  enabled         Boolean       @default(false)
  encryptedSecret String?
  scopes          String[]      @default([])
  metadata        Json?
  lastSyncAt      DateTime?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([kind, name])
}

// ── Provider Call ledger ────────────────────────────────────────────────────

model ProviderCall {
  id              String   @id @default(cuid())
  userId          String?
  user            User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  provider        String
  model           String
  taskClass       String
  promptTokens    Int      @default(0)
  completionTokens Int     @default(0)
  costUsd         Float    @default(0)
  latencyMs       Int      @default(0)
  redactionApplied Boolean @default(false)
  sensitivity     SensitivityLevel?
  ok              Boolean  @default(true)
  errorMessage    String?
  createdAt       DateTime @default(now())

  @@index([provider])
  @@index([createdAt])
}

// ── Personal Question Mode ───────────────────────────────────────────────────

enum QuestionDomain {
  COMMAND_STYLE
  FAITH
  FATHERHOOD
  BUSINESS
  RELATIONSHIPS
  EMOTIONAL_PATTERNS
  HEALTH
  RISK
  MONEY
  LEGAL
  LEGACY
  COMMUNICATION_STYLE
  BOUNDARIES
  CURRENT_MISSIONS
}

enum QuestionStatus {
  UNASKED
  ASKED
  ANSWERED
  DEFERRED
  RETIRED
}

enum EmotionalWeight {
  LIGHT
  MODERATE
  HEAVY
}

enum QuestionTiming {
  ANYTIME
  QUIET_MOMENT
  EXPLICIT_PERSONAL_MODE
  ONLY_IF_RELEVANT
}

enum QuestionGeneratedBy {
  SYSTEM
  VIRGIL
  MANUAL
}

enum InferenceSensitivity {
  LOW
  MEDIUM
  HIGH
  SACRED
}

enum InferenceStatus {
  PENDING_REVIEW
  APPROVED
  EDITED
  REJECTED
  SAVED
}

enum SessionDepth {
  LIGHT
  STANDARD
  DEEP
}

enum SessionStatus {
  ACTIVE
  COMPLETED
  ABANDONED
}

model VirgilQuestion {
  id                    String              @id @default(cuid())
  userId                String
  user                  User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  domain                QuestionDomain
  question              String
  reason                String
  priority              Int                 @default(5)
  emotionalWeight       EmotionalWeight     @default(LIGHT)
  timing                QuestionTiming      @default(ANYTIME)
  status                QuestionStatus      @default(UNASKED)
  generatedBy           QuestionGeneratedBy @default(SYSTEM)
  sourceConversationId  String?
  followups             String[]            @default([])
  askedAt               DateTime?
  answeredAt            DateTime?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  answers               VirgilQuestionAnswer[]
  inferences            VirgilMemoryInference[]

  @@index([userId])
  @@index([domain])
  @@index([status])
  @@index([priority])
}

model VirgilQuestionAnswer {
  id                    String   @id @default(cuid())
  questionId            String
  question              VirgilQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
  userId                String
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  answer                String
  userApprovedForMemory Boolean  @default(false)
  userRejectedForMemory Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  inferences            VirgilMemoryInference[]

  @@index([questionId])
  @@index([userId])
}

model VirgilMemoryInference {
  id              String               @id @default(cuid())
  userId          String
  user            User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  questionId      String?
  question        VirgilQuestion?      @relation(fields: [questionId], references: [id], onDelete: SetNull)
  answerId        String?
  answer          VirgilQuestionAnswer? @relation(fields: [answerId], references: [id], onDelete: SetNull)
  proposedMemory  String
  category        String
  confidence      Float                @default(0.8)
  sensitivity     InferenceSensitivity @default(MEDIUM)
  inferenceReason String?
  status          InferenceStatus      @default(PENDING_REVIEW)
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt

  @@index([userId])
  @@index([status])
  @@index([questionId])
}

model VirgilProfileDomain {
  id                   String         @id @default(cuid())
  userId               String
  user                 User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  domain               QuestionDomain
  summary              String?
  understandingScore   Int            @default(0)
  confirmedMemoryCount Int            @default(0)
  openQuestionCount    Int            @default(0)
  lastUpdatedAt        DateTime?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  @@unique([userId, domain])
  @@index([userId])
}

model VirgilQuestionSession {
  id             String        @id @default(cuid())
  userId         String
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  depth          SessionDepth  @default(STANDARD)
  selectedDomain QuestionDomain?
  questionIds    String[]      @default([])
  startedAt      DateTime      @default(now())
  completedAt    DateTime?
  status         SessionStatus @default(ACTIVE)

  @@index([userId])
  @@index([status])
}

// ── Veronica Privacy Architecture ────────────────────────────────────────────
//
// Stella's conversations are encrypted with a key derived from her CPF +
// password. The key never touches the database. Even the server admin cannot
// read her data. This is enforced by mathematics, not policy.

/// Every data access touching Stella's rows is logged here. Signed with her
/// derived key so she can independently verify no unauthorized access occurred.
model VeronicaPrivacyAudit {
  id             String   @id @default(cuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  action         String   // "DECRYPT" | "QUERY" | "LOGIN" | "KEY_DERIVE" | "CONVERSATION_STORE"
  detail         String   // human-readable description
  ipHash         String?  // hashed IP — not raw
  signature      String?  // HMAC signed with Stella's key — verifiable only by her
  createdAt      DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
  @@index([action])
}

/// Stella's conversations — encrypted at rest with her derived key.
/// Content is ciphertext. Cannot be decrypted without CPF + password.
model VeronicaConversation {
  id                String   @id @default(cuid())
  userId            String   // Stella's user ID
  encryptedContent  String   // AES-256-GCM ciphertext (base64)
  encryptedSummary  String?  // encrypted summary for retrieval
  searchHash        String?  // deterministic hash of keywords for search (no plaintext)
  tokenEstimate     Int      @default(0)
  createdAt         DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

/// Stella's memories — same encryption as conversations.
model VeronicaMemory {
  id                 String   @id @default(cuid())
  userId             String
  encryptedTitle     String   // AES-256-GCM ciphertext
  encryptedContent   String   // AES-256-GCM ciphertext
  category           String   // stored in plaintext for filtering only — no sensitive data
  sensitivityLevel   String   @default("PERSONAL_PRIVATE")
  importance         Int      @default(50)
  status             String   @default("ACTIVE")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@index([userId])
  @@index([category])
  @@index([status])
  @@index([createdAt])
}

// ── Profile Facts ────────────────────────────────────────────────────────────
// Structured bullet-point facts about Rosser or Stella.
// Simple key-value store with category grouping.
// Stella facts are visible to Verônica's knowledge base.

enum ProfileSubject {
  ROSSER
  STELLA
}

model ProfileFact {
  id               String         @id @default(cuid())
  subject          ProfileSubject
  category         String         // "Travel", "Health", "Accounts", "Preferences", "Family", etc.
  label            String         // "Delta Skymiles Number", "Birthday", "Favorite food", etc.
  value            String         // the actual fact (plaintext)
  encrypted        Boolean        @default(false)
  encryptedValue   String?        // AES-256-GCM ciphertext when encrypted=true
  veronicaVisible  Boolean        @default(false)  // Stella facts only — allow Verônica to use
  pinned           Boolean        @default(false)
  sortOrder        Int            @default(0)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([subject])
  @@index([subject, category])
  @@index([veronicaVisible])
}

// ── Virgil Conversations ─────────────────────────────────────────────────────
// Persistent conversation history for Rosser ↔ Virgil chat sessions.

enum MessageFeedback {
  UP
  DOWN
}

model VirgilConversation {
  id        String           @id @default(cuid())
  userId    String
  companion String           @default("VIRGIL")  // "VIRGIL" | "VERONICA"
  title     String?          // auto-set from first user message (first 60 chars)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  messages  VirgilMessage[]

  @@index([userId])
  @@index([userId, companion])
  @@index([createdAt])
}

model VirgilMessage {
  id             String              @id @default(cuid())
  conversationId String
  conversation   VirgilConversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String              // "user" | "assistant"
  content        String
  meta           Json?               // { usedModel, sensitivity, blackDoor }
  feedback       MessageFeedback?
  feedbackNote   String?
  createdAt      DateTime            @default(now())

  @@index([conversationId])
  @@index([createdAt])
}
